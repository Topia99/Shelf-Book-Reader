# Shelf iOS 发布流水线（P4-10 TestFlight）
# 凭证由 tools/release-ios-testflight.sh 从 .env.asc.local(gitignored) source 进环境：
#   ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH(.p8 路径) / ASC_APP_IDENTIFIER / ASC_TEAM_ID
# 构建由 tauri ios build 产 IPA，本 Fastfile 只负责校验与上传。

default_platform(:ios)

platform :ios do
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false
    )
  end

  desc "快速校验：ASC 凭证有效 + App 已在 App Store Connect 建好（不构建）"
  lane :validate do
    n = latest_testflight_build_number(
      api_key: asc_api_key,
      app_identifier: ENV.fetch("ASC_APP_IDENTIFIER", "com.shelf.reader"),
      initial_build_number: 0
    )
    UI.success("✓ ASC 凭证有效；TestFlight 当前最新构建号：#{n}")
  end

  desc "上传已由 tauri ios build 产出的 IPA 到 TestFlight"
  lane :beta do
    # 默认路径相对 Fastfile 自身（fastlane/），不受 fastlane 运行时 cwd 影响
    default_ipa = File.expand_path("../src-tauri/gen/apple/build/arm64/Shelf.ipa", __dir__)
    ipa = ENV.fetch("IPA_PATH", default_ipa)
    UI.user_error!("IPA 不存在：#{ipa}（先跑 tauri ios build）") unless File.exist?(ipa)
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: ENV.fetch("ASC_APP_IDENTIFIER", "com.shelf.reader"),
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      changelog: "Shelf 内部测试版本"
    )
  end
end

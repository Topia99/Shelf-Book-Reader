# App Store Connect API 凭证（P4-10 TestFlight 上传用）
# 复制本文件为 .env.asc.local（已被 .gitignore 的 *.local 覆盖，不会入库）并填入真实值。
# .p8 私钥文件本身存仓库外（如 ~/.appstoreconnect/private_keys/），绝不粘贴进对话或提交。

# App Store Connect → Users and Access → Integrations → App Store Connect API 生成密钥后：
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=/Users/jasonzeng/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8

# Apple 开发者 Team ID（供 fastlane/导出用）
ASC_TEAM_ID=R59Q7NXAWD
# App 的 Bundle ID
ASC_APP_IDENTIFIER=com.shelf.reader
